# data + artifacts are reproducible from the pipeline; never commit them
data/raw/*
data/processed/*
data/models/*
!data/**/.gitkeep

*.duckdb
*.parquet
*.joblib
*.pt

# Reports are regenerated by every training run, but the committed copy is the
# published evidence for the results quoted in the README - and the README links
# to it, so it must exist in the repository.
reports/*
!reports/.gitkeep
!reports/model_report.md
!reports/metrics.json

# secrets / credentials - must never reach the repo
.env
*-service-account.json
*credentials*.json
!config/config.yaml

# terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfvars
!terraform/*.tfvars.example
.terraform.lock.hcl

# python
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
*.egg-info/
build/
dist/
.venv/
venv/

# os / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
