# Keep the build context small - it is uploaded to the daemon on every build.
.git/
.github/
terraform/
tests/
docs/
reports/
notebooks/

# Data is reproducible from the pipeline and must not be baked into an image.
data/raw/
data/processed/
*.duckdb
*.parquet

# Never ship credentials.
.env
*service-account*.json
*credentials*.json

__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.venv/
venv/
*.egg-info/

README.md
Makefile
requirements-dev.txt
